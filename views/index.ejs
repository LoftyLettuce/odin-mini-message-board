<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="styles.css"/>
  <title><%= title%></title>
</head>
<body>
    <h1 ><%= title%></h1>
    <button><a href="/new">Add message</a></button>
    <ul class="messages-board">
      <% for(let i = 0; i < messages.length; i++){%>
        <li class="message-container">
          <div class="message-meta">
          <span><%= messages[i].user%></span>
          <span><%= messages[i].added%></span>
            <span><button><a href=<%= `/messages/${i}`%>>Details</a></button></span>
          </div>
          <p><%= messages[i].text%></p>
        </li>
      <%}%>
    </ul>
</body>
</html>
